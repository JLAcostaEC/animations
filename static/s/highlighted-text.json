{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "highlighted-text",
	"title": "Highlighted Text",
	"type": "registry:block",
	"description": "An inline highlight sweep that reveals text from configurable directions with optional viewport triggers.",
	"dependencies": [
		"motion-sv"
	],
	"files": [
		{
			"content": "<script lang=\"ts\">\n\timport { cn } from \"$UTILS$\";\n\timport { motion, useInView, type AnimationOptions, type Variants } from \"motion-sv\";\n\timport type { Snippet } from \"svelte\";\n\timport type { HTMLAttributes } from \"svelte/elements\";\n\n\ttype From = \"left\" | \"right\" | \"top\" | \"bottom\";\n\n\tinterface HighlightedTextProps extends HTMLAttributes<HTMLSpanElement> {\n\t\tchildren?: Snippet;\n\t\tclass?: string;\n\t\tfrom?: From;\n\t\tdelay?: number;\n\t\ttriggerOnView?: boolean;\n\t\tonce?: boolean;\n\t}\n\n\tconst transition: AnimationOptions = {\n\t\ttype: \"spring\",\n\t\tdamping: 30,\n\t\tstiffness: 300,\n\t};\n\n\tconst fromVariants: Record<From, Variants> = {\n\t\tleft: {\n\t\t\thidden: { x: \"-100%\" },\n\t\t\tvisible: { x: \"0%\" },\n\t\t},\n\t\tright: {\n\t\t\thidden: { x: \"100%\" },\n\t\t\tvisible: { x: \"0%\" },\n\t\t},\n\t\ttop: {\n\t\t\thidden: { y: \"-100%\" },\n\t\t\tvisible: { y: \"0%\" },\n\t\t},\n\t\tbottom: {\n\t\t\thidden: { y: \"100%\" },\n\t\t\tvisible: { y: \"0%\" },\n\t\t},\n\t};\n\n\tlet {\n\t\tchildren,\n\t\tclass: className,\n\t\tfrom = \"bottom\",\n\t\tdelay = 0,\n\t\ttriggerOnView = false,\n\t\tonce = true,\n\t\t...props\n\t}: HighlightedTextProps = $props();\n\n\tlet element = $state<HTMLSpanElement | null>(null);\n\tlet view = useInView(\n\t\t() => (triggerOnView ? element : null)!,\n\t\t() => ({ once, amount: 0.2 }) as any\n\t);\n\n\tconst variants = $derived(fromVariants[from]);\n\tconst isVisible = $derived(triggerOnView ? view.current : true);\n</script>\n\n<span\n\tbind:this={element}\n\tclass={cn(\"relative inline-flex overflow-hidden align-baseline\", className)}\n\t{...props}\n>\n\t<motion.span\n\t\tclass=\"absolute inset-0 -right-[0.18em] -left-[0.15em] z-0 bg-black dark:bg-white\"\n\t\tinitial=\"hidden\"\n\t\tanimate={isVisible ? \"visible\" : \"hidden\"}\n\t\t{variants}\n\t\ttransition={{ ...transition, delay }}\n\t/>\n\t<span class=\"relative z-10 pr-[0.18em] pl-[0.15em] text-white mix-blend-difference\">\n\t\t{@render children?.()}\n\t</span>\n</span>\n",
			"type": "registry:component",
			"target": "spell/highlighted-text/highlighted-text.svelte"
		},
		{
			"content": "import HighlightedText from \"./highlighted-text.svelte\";\r\nexport { HighlightedText };",
			"type": "registry:file",
			"target": "spell/highlighted-text/index.ts"
		}
	]
}