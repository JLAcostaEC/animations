{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "pulsating-button",
	"title": "Pulsating Button",
	"type": "registry:block",
	"description": "A button component with a pulsating ring effect that expands and fades around the button.",
	"css": {
		"@keyframes pulse-ring": {
			"0%": {
				"box-shadow": "0 0 0 0 var(--pulse-color)"
			},
			"100%": {
				"box-shadow": "0 0 0 8px transparent"
			}
		}
	},
	"cssVars": {
		"theme": {
			"animate-pulse-ring": "pulse-ring var(--duration) ease-out infinite"
		}
	},
	"files": [
		{
			"content": "<script lang=\"ts\">\r\n\timport { cn } from \"$UTILS$\";\r\n\timport type { Snippet } from \"svelte\";\r\n\r\n\tinterface PulsatingButtonProps {\r\n\t\tchildren: Snippet;\r\n\t\tclass?: string;\r\n\t\tpulseColor?: string;\r\n\t\tduration?: string;\r\n\t}\r\n\r\n\tlet {\r\n\t\tclass: className,\r\n\t\tchildren,\r\n\t\tpulseColor = \"#808080\",\r\n\t\tduration = \"1.5s\",\r\n\t\t...props\r\n\t}: PulsatingButtonProps = $props();\r\n</script>\r\n\r\n<button\r\n\tclass={cn(\r\n\t\t\"bg-primary text-primary-foreground relative flex cursor-pointer items-center justify-center rounded-lg px-4 py-2 text-center\",\r\n\t\tclassName\r\n\t)}\r\n\tstyle=\"--pulse-color: {pulseColor}; --duration: {duration};\"\r\n\t{...props}\r\n>\r\n\t<div class=\"relative z-10\">\r\n\t\t{@render children()}\r\n\t</div>\r\n\t<div\r\n\t\tclass=\"animate-pulse-ring absolute top-1/2 left-1/2 size-full -translate-x-1/2 -translate-y-1/2 rounded-lg bg-inherit\"\r\n\t></div>\r\n</button>\r\n",
			"type": "registry:component",
			"target": "magic/pulsating-button/pulsating-button.svelte"
		},
		{
			"content": "export { default as PulsatingButton } from \"./pulsating-button.svelte\";\r\n",
			"type": "registry:file",
			"target": "magic/pulsating-button/index.ts"
		}
	]
}